          "nodeBackground": "linear-gradient(145deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.03) 100%)",
          "nodeShadow": "0 4px 20px rgba(0,0,0,0.2), 0 1px 4px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,255,0.05)",
          "edgeShadow": "rgba(245,197,106,0.1)",
          "edgeLabelBg": "#2E4233",
          "edgeLabelBorder": "rgba(245,197,106,0.2)",
          "textOnAccent": "#1E2D22",
          "stepPast": "rgba(245,197,106,0.25)",
          "stepInactive": "rgba(232,228,217,0.08)",
          "stepInactiveBorder": "rgba(232,228,217,0.15)"
        },
        "glow": {
          "title": "radial-gradient(circle, rgba(245,197,106,0.1) 0%, transparent 70%)"
        }
      },
      "animation": {
        "spring": {
          "default": { "damping": 14, "stiffness": 80, "mass": 0.8 },
          "bouncy": { "damping": 10, "stiffness": 100, "mass": 0.6 },
          "gentle": { "damping": 16, "stiffness": 60, "mass": 0.6 },
          "snappy": { "damping": 10, "stiffness": 120, "mass": 0.5 },
