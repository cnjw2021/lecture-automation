          "textMuted": "rgba(232,228,217,0.5)",
          "accent": "#F5C56A",
          "accentSecondary": "#7EC8A0",
          "accentMuted": "rgba(245,197,106,0.2)",
          "surface": "rgba(245,197,106,0.1)",
