# 오디오 프로바이더 선택: gemini | google_cloud_tts
AUDIO_PROVIDER=google_cloud_tts

# Google Gemini API Key
# https://aistudio.google.com/app/apikey 에서 발급받은 키를 입력하세요.
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud TTS Service Account
# https://console.cloud.google.com/iam-admin/serviceaccounts 에서 JSON 키 발급
GOOGLE_CLOUD_TTS_KEY_FILE=./.credentials/google-cloud-tts.json
GOOGLE_CLOUD_TTS_VOICE=ja-JP-Chirp3-HD-Fenrir
GOOGLE_CLOUD_TTS_LANGUAGE_CODE=ja-JP

ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# AWS
AWS_REGION=ap-northeast-1
REMOTION_LAMBDA_FUNCTION_NAME=remotion-render-4-0-443-mem2048mb-disk2048mb-900sec
REMOTION_SERVE_URL=https://your-bucket.s3.ap-northeast-1.amazonaws.com/sites/lecture-automation/index.html

# Lambda 렌더링 설정 — 자세한 근거는 docs/lambda-render-config.md 참조
# 씬 분포 분석(925개 씬) 결과 권장값: 90% 씬은 단일 청크, 620초 씬은 10청크 병렬
REMOTION_LAMBDA_FRAMES_PER_LAMBDA=2000

# 동시 실행 씬 수 (기본값: 20)
# REMOTION_LAMBDA_CONCURRENCY=20

# Lambda 인스턴스당 브라우저 탭 수. 미설정 시 Remotion 기본값 사용
# REMOTION_LAMBDA_TAB_CONCURRENCY=
